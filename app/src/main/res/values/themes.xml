<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.NammaPlatform" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/railway_blue</item>
        <item name="colorPrimaryVariant">@color/railway_blue_light</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/railway_yellow</item>
        <item name="colorOnSecondary">@color/text_dark</item>
        <item name="android:windowBackground">@color/screen_bg</item>
        <item name="android:statusBarColor">@color/railway_blue</item>
        <item name="android:navigationBarColor">@color/railway_blue</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
    </style>

    <style name="TrainCardStyle" parent="CardStyle">
        <item name="cardElevation">6dp</item>
    </style>

    <style name="CoachLabelStyle">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="SpeakButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/railway_yellow</item>
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">16sp</item>
        <item name="android:padding">16dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:fontFamily">sans-serif-bold</item>
    </style>
</resources>
